{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "zmux": {
    "version": "1.0.0",
    "tlcCompliant": true,
    "colors": {
      "sanctuary": {
        "gold": {
          "$value": "#C9A05A",
          "$type": "color",
          "$description": "Primary brand color - Soul Gold"
        },
        "teal": {
          "$value": "#5B9A8B",
          "$type": "color",
          "$description": "Clinical accent - Clinical Teal"
        },
        "terracotta": {
          "$value": "#C4785A",
          "$type": "color",
          "$description": "Warm accent - Terracotta"
        },
        "cream": {
          "$value": "#FAF8F5",
          "$type": "color",
          "$description": "Warm background"
        },
        "sage": {
          "$value": "#B8C5B2",
          "$type": "color",
          "$description": "Calming secondary"
        }
      },
      "semantic": {
        "truth": {
          "t1": {
            "$value": "#22C55E",
            "$type": "color",
            "$description": "Verified claims"
          },
          "t2": {
            "$value": "#C9A05A",
            "$type": "color",
            "$description": "Probable claims"
          },
          "t3": {
            "$value": "#F59E0B",
            "$type": "color",
            "$description": "Uncertain claims"
          }
        },
        "mood": {
          "calm": {
            "$value": "#22C55E",
            "$type": "color"
          },
          "neutral": {
            "$value": "#5B9A8B",
            "$type": "color"
          },
          "stressed": {
            "$value": "#F59E0B",
            "$type": "color"
          },
          "crisis": {
            "$value": "#EF4444",
            "$type": "color"
          }
        },
        "risk": {
          "low": {
            "$value": "#22C55E",
            "$type": "color"
          },
          "medium": {
            "$value": "#F59E0B",
            "$type": "color"
          },
          "high": {
            "$value": "#F97316",
            "$type": "color"
          },
          "critical": {
            "$value": "#EF4444",
            "$type": "color"
          }
        }
      }
    },
    "typography": {
      "fontFamily": {
        "sans": {
          "$value": "Source Sans 3, system-ui, sans-serif",
          "$type": "fontFamily"
        },
        "serif": {
          "$value": "Source Serif 4, Georgia, serif",
          "$type": "fontFamily"
        },
        "mono": {
          "$value": "JetBrains Mono, Menlo, monospace",
          "$type": "fontFamily"
        }
      },
      "fontSize": {
        "xs": { "$value": "0.875rem", "$type": "dimension" },
        "sm": { "$value": "1rem", "$type": "dimension" },
        "base": { "$value": "1.125rem", "$type": "dimension" },
        "lg": { "$value": "1.25rem", "$type": "dimension" },
        "xl": { "$value": "1.5rem", "$type": "dimension" },
        "2xl": { "$value": "2rem", "$type": "dimension" }
      },
      "lineHeight": {
        "tight": { "$value": "1.25", "$type": "number" },
        "normal": { "$value": "1.5", "$type": "number" },
        "relaxed": { "$value": "1.7", "$type": "number" }
      }
    },
    "spacing": {
      "base": { "$value": "4px", "$type": "dimension" },
      "scale": {
        "1": { "$value": "4px", "$type": "dimension" },
        "2": { "$value": "8px", "$type": "dimension" },
        "3": { "$value": "12px", "$type": "dimension" },
        "4": { "$value": "16px", "$type": "dimension" },
        "6": { "$value": "24px", "$type": "dimension" },
        "8": { "$value": "32px", "$type": "dimension" },
        "12": { "$value": "48px", "$type": "dimension" },
        "16": { "$value": "64px", "$type": "dimension" }
      }
    },
    "borderRadius": {
      "sm": { "$value": "6px", "$type": "dimension" },
      "md": { "$value": "8px", "$type": "dimension" },
      "lg": { "$value": "12px", "$type": "dimension" },
      "xl": { "$value": "16px", "$type": "dimension" },
      "full": { "$value": "9999px", "$type": "dimension" }
    },
    "motion": {
      "duration": {
        "instant": { "$value": "0ms", "$type": "duration" },
        "fast": { "$value": "150ms", "$type": "duration" },
        "normal": { "$value": "300ms", "$type": "duration" },
        "slow": { "$value": "500ms", "$type": "duration" }
      },
      "easing": {
        "default": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
        "in": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
        "out": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" }
      }
    },
    "safety": {
      "invariants": {
        "I1": "Epistemic Safety",
        "I2": "Human Safety",
        "I3": "Consent Safety",
        "I4": "Cognitive Safety",
        "I5": "Emotional Safety",
        "I6": "Empirical Safety"
      }
    },
    "accessibility": {
      "wcag": {
        "level": "AAA",
        "version": "2.2"
      },
      "features": [
        "keyboard-navigation",
        "screen-reader-optimized",
        "reduced-motion-support",
        "high-contrast-mode",
        "focus-indicators"
      ]
    }
  }
}
